{
  "name": "agent-scaffold-ts",
  "version": "0.1.0",
  "description": "TypeScript framework for LLM-powered multi-agent pipelines with adaptive replanning",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "agent",
    "llm",
    "ai",
    "multi-agent",
    "orchestrator",
    "gemini",
    "openai",
    "anthropic",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clairexin/agent-scaffold.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx examples/basic-run.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
